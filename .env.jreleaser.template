#!/bin/bash
# Template for jReleaser deployment environment variables
# Copy this file to .env.jreleaser and fill in your actual values
# Then run: source .env.jreleaser

# =============================================================================
# Maven Central Credentials
# =============================================================================
# Get these from: https://central.sonatype.com/account
# NOTE: Use your Maven Central Portal token, NOT your legacy OSSRH password
export MAVEN_USERNAME="your-maven-central-username"
export MAVEN_PASSWORD="your-maven-central-token"

# =============================================================================
# GPG Signing Configuration
# =============================================================================
# Your GPG key passphrase
export JRELEASER_GPG_PASSPHRASE="your-gpg-passphrase"

# Option 1: Load GPG keys from files (RECOMMENDED)
# Generate with:
#   gpg --armor --export-secret-keys YOUR_KEY_ID > private-key.asc
#   gpg --armor --export YOUR_KEY_ID > public-key.asc
export JRELEASER_GPG_SECRET_KEY="$(cat private-key.asc)"
export JRELEASER_GPG_PUBLIC_KEY="$(cat public-key.asc)"

# Option 2: Paste keys directly (uncomment and replace with actual keys)
# export JRELEASER_GPG_SECRET_KEY="-----BEGIN PGP PRIVATE KEY BLOCK-----
#
# YOUR PRIVATE KEY HERE (keep the BEGIN/END lines)
#
# -----END PGP PRIVATE KEY BLOCK-----"
#
# export JRELEASER_GPG_PUBLIC_KEY="-----BEGIN PGP PUBLIC KEY BLOCK-----
#
# YOUR PUBLIC KEY HERE (keep the BEGIN/END lines)
#
# -----END PGP PUBLIC KEY BLOCK-----"

# =============================================================================
# Duplicate credentials for different variable names
# =============================================================================
# Some plugins expect different variable names, so we set them all
export JRELEASER_MAVENCENTRAL_USERNAME="$MAVEN_USERNAME"
export JRELEASER_MAVENCENTRAL_PASSWORD="$MAVEN_PASSWORD"
export GPG_PRIVATE_KEY="$JRELEASER_GPG_SECRET_KEY"
export GPG_PASSPHRASE="$JRELEASER_GPG_PASSPHRASE"

# =============================================================================
# Verification
# =============================================================================
echo "✅ Environment variables loaded successfully!"
echo ""
echo "Loaded variables:"
echo "  MAVEN_USERNAME: ${MAVEN_USERNAME:0:10}***"
echo "  MAVEN_PASSWORD: ${MAVEN_PASSWORD:0:10}***"
echo "  GPG keys: $([ -n "$JRELEASER_GPG_SECRET_KEY" ] && echo 'Set' || echo 'NOT SET')"
echo ""
echo "You can now run: ./gradlew jreleaserDeploy"

