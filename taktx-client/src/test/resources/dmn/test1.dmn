<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="test1" name="Test1" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="test-decision" name="Test Decision">
    <decisionTable id="dt1" hitPolicy="UNIQUE">
      <input id="i1" label="Input">
        <inputExpression id="ie1" typeRef="string">
          <text>input</text>
        </inputExpression>
      </input>
      <output id="o1" label="Output" name="output" typeRef="string"/>
      <rule id="r1">
        <inputEntry id="in1"><text>"yes"</text></inputEntry>
        <outputEntry id="out1"><text>"ok"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>

