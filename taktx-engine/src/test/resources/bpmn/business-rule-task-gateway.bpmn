<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_brtgateway" targetNamespace="http://bpmn.io/schema/bpmn">
  <!--
    Test BPMN that proves the "no output mappings → propagate all" fix.

    Flow: StartEvent → BusinessRuleTask (evaluates discountDecision, resultVariable=discount)
                     → ExclusiveGateway (condition on 'discount')
                     → EndEvent_Premium  (discount >= 0.2)
                  OR → EndEvent_Default  (default / discount < 0.2)

    Without the fix the gateway cannot see 'discount' because it lives only in the
    BusinessRuleTask's local scope and is never copied to the process scope.
    With the fix (no output mappings ⟹ propagate all dirty local vars), the gateway
    can evaluate the condition correctly.
  -->
  <bpmn:process id="Process_brtgateway" isExecutable="true">

    <bpmn:startEvent id="StartEvent_1">
      <bpmn:outgoing>Flow_Start_BRT</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:sequenceFlow id="Flow_Start_BRT" sourceRef="StartEvent_1" targetRef="BusinessRuleTask_1"/>

    <bpmn:businessRuleTask id="BusinessRuleTask_1" name="Determine Discount">
      <bpmn:extensionElements>
        <!-- No zeebe:ioMapping — intentionally no output mappings to trigger the bug -->
        <zeebe:calledDecision decisionId="discountDecision" resultVariable="discount"/>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Start_BRT</bpmn:incoming>
      <bpmn:outgoing>Flow_BRT_GW</bpmn:outgoing>
    </bpmn:businessRuleTask>

    <bpmn:sequenceFlow id="Flow_BRT_GW" sourceRef="BusinessRuleTask_1" targetRef="Gateway_1"/>

    <bpmn:exclusiveGateway id="Gateway_1" name="Discount routing" default="Flow_to_default">
      <bpmn:incoming>Flow_BRT_GW</bpmn:incoming>
      <bpmn:outgoing>Flow_to_premium</bpmn:outgoing>
      <bpmn:outgoing>Flow_to_default</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sequenceFlow id="Flow_to_premium" sourceRef="Gateway_1" targetRef="EndEvent_Premium">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=discount >= 0.2</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_to_default" sourceRef="Gateway_1" targetRef="EndEvent_Default"/>

    <bpmn:endEvent id="EndEvent_Premium" name="Premium End">
      <bpmn:incoming>Flow_to_premium</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_Default" name="Default End">
      <bpmn:incoming>Flow_to_default</bpmn:incoming>
    </bpmn:endEvent>

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_brtgateway">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="152" y="82" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BusinessRuleTask_1_di" bpmnElement="BusinessRuleTask_1">
        <dc:Bounds x="260" y="60" width="100" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_1_di" bpmnElement="Gateway_1" isMarkerVisible="true">
        <dc:Bounds x="435" y="75" width="50" height="50"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="416" y="132" width="90" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Premium_di" bpmnElement="EndEvent_Premium">
        <dc:Bounds x="572" y="82" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="557" y="125" width="67" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Default_di" bpmnElement="EndEvent_Default">
        <dc:Bounds x="572" y="192" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="557" y="235" width="67" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_Start_BRT_di" bpmnElement="Flow_Start_BRT">
        <di:waypoint x="188" y="100"/>
        <di:waypoint x="260" y="100"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_BRT_GW_di" bpmnElement="Flow_BRT_GW">
        <di:waypoint x="360" y="100"/>
        <di:waypoint x="435" y="100"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_to_premium_di" bpmnElement="Flow_to_premium">
        <di:waypoint x="485" y="100"/>
        <di:waypoint x="572" y="100"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_to_default_di" bpmnElement="Flow_to_default">
        <di:waypoint x="460" y="125"/>
        <di:waypoint x="460" y="210"/>
        <di:waypoint x="572" y="210"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>

